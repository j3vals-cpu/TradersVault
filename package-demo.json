{
  "appId": "com.j3traders.vault.demo",
  "productName": "Traders Vault Demo",
  "copyright": "Copyright \u00a9 2026 J3 | Traders Vault \u2014 Vaulted Desk",
  "asar": true,
  "directories": {
    "output": "dist-demo"
  },
  "files": [
    "main-demo.js",
    "preload.js",
    "index.html",
    "splash.html",
    "html2canvas.min.js",
    "assets/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "assets/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "executableName": "TradersVaultDemo"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Traders Vault Demo",
    "runAfterFinish": true,
    "deleteAppDataOnUninstall": false
  },
  "portable": {
    "artifactName": "TradersVault-Demo-portable.exe"
  },
  "mac": {
    "target": "pkg",
    "icon": "assets/icon.png",
    "category": "public.app-category.finance",
    "minimumSystemVersion": "10.15",
    "darkModeSupport": true,
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "pkg": {
    "installLocation": "/Applications",
    "allowAnywhere": true,
    "allowCurrentUserHome": true,
    "allowRootDirectory": true,
    "artifactName": "Traders-Vault-Demo-${version}-${arch}.pkg"
  },
  "linux": {
    "target": [
      "AppImage"
    ],
    "icon": "assets/icon.png",
    "category": "Finance"
  }
}