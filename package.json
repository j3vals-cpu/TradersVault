{
  "name": "traders-vault",
  "productName": "Traders Vault",
  "version": "2.1.4",
  "description": "Traders Vault \u2014 Vaulted Desk. The overlay trading command centre for prop traders.",
  "main": "main.js",
  "author": "J3 | Traders Vault \u2014 Vaulted Desk",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:mac": "electron-builder --mac --x64 && electron-builder --mac --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:all": "electron-builder --win --x64 && electron-builder --mac --x64 && electron-builder --mac --arm64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.j3traders.vault",
    "productName": "Traders Vault",
    "copyright": "Copyright \u00a9 2026 J3 | Traders Vault \u2014 Vaulted Desk",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "splash.html",
      "html2canvas.min.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "executableName": "TradersVault"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Traders Vault",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "TradersVault-portable.exe"
    },
    "mac": {
      "target": "pkg",
      "icon": "assets/icon.png",
      "category": "public.app-category.finance",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "pkg": {
      "installLocation": "/Applications",
      "allowAnywhere": true,
      "allowCurrentUserHome": true,
      "allowRootDirectory": true,
      "artifactName": "Traders-Vault-${version}-${arch}.pkg"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Finance"
    }
  }
}